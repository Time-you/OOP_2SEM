#include <iostream>
using namespace std;

double averagePositive(int arr[], int n)
{
    int count = 0;
    int sum = 0;

    for (int i = 0; i < n; i++)
    {
        if (arr[i] > 0)
        {
            sum += arr[i];
            count++;
        }
    }

    if (count == 0)
        throw "Dodatni chisla vidsutni";

    return (double)sum / count;
}

int main()
{
    int n;
    cout << "Vvedit kilkist elementiv: ";
    cin >> n;

    int* arr = new int[n];

    cout << "Vvedit elementi masivu:\n";
    for (int i = 0; i < n; i++)
        cin >> arr[i];

    try
    {
        double avg = averagePositive(arr, n);
        cout << "Seredne arifmetychne dodatnih chysel = " << avg << endl;
    }
    catch (const char* msg)
    {
        cerr << "Pomylka: " << msg << endl;
    }

    delete[] arr;
    return 0;
}
