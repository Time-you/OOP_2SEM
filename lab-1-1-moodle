#include <iostream>
#include <cmath>
using namespace std;

class Point {
protected:
    double x, y;

public:
    Point() {
        x = 0; y = 0;
        cout << "Default constructor Point\n";
    }

    Point(double _x, double _y) {
        x = _x; y = _y;
        cout << "Constructor Point(double x, double y)\n";
    }

    ~Point() {
        cout << "Destructor Point\n";
    }

    void setX(double _x) { x = _x; }
    void setY(double _y) { y = _y; }

    virtual string toString() {
        return "Point: (" + to_string(x) + ", " + to_string(y) + ")";
    }

    virtual void Input() {
        cout << "Input x: "; cin >> x;
        cout << "Input y: "; cin >> y;
    }

    virtual void Output() {
        cout << toString() << endl;
    }
};

class Ellipse : public Point {
protected:
    double a, b; // півосі

public:
    Ellipse() : Point() {
        a = 0; b = 0;
        cout << "Default constructor Ellipse\n";
    }

    Ellipse(double _x, double _y, double _a, double _b)
        : Point(_x, _y) {
        a = _a; b = _b;
        cout << "Constructor Ellipse(x,y,a,b)\n";
    }

    ~Ellipse() {
        cout << "Destructor Ellipse\n";
    }

    void setA(double _a) { a = _a; }
    void setB(double _b) { b = _b; }

    double area() {
        return M_PI * a * b;
    }

    string toString() override {
        return Point::toString() +
            " Ellipse a=" + to_string(a) +
            " b=" + to_string(b) +
            " Area=" + to_string(area());
    }

    void Input() override {
        Point::Input();
        cout << "Input a: "; cin >> a;
        cout << "Input b: "; cin >> b;
    }

    void Output() override {
        cout << toString() << endl;
    }
};

class Circle : public Ellipse {
public:
    Circle() : Ellipse() {
        cout << "Default constructor Circle\n";
    }

    Circle(double _x, double _y, double r)
        : Ellipse(_x, _y, r, r) {
        cout << "Constructor Circle(x,y,r)\n";
    }

    ~Circle() {
        cout << "Destructor Circle\n";
    }

    void setRadius(double r) {
        a = b = r;
    }

    double area() {
        return M_PI * a * a;
    }

    string toString() override {
        return Point::toString() +
            " Circle r=" + to_string(a) +
            " Area=" + to_string(area());
    }

    void Input() override {
        Point::Input();
        cout << "Input radius: "; cin >> a;
        b = a;
    }

    void Output() override {
        cout << toString() << endl;
    }
};

int main() {
    char choice;

    do {
        cout << "\nMENU:\n";
        cout << "1 - Default Point\n";
        cout << "2 - Input Ellipse\n";
        cout << "3 - Constructor Circle\n";
        cout << "4 - Set radius\n";
        cout << "q - Quit\n";
        cout << "Choice: ";
        cin >> choice;

        switch (choice) {
        case '1': {
            Point p;
            p.Output();
            break;
        }
        case '2': {
            Ellipse e;
            e.Input();
            e.Output();
            break;
        }
        case '3': {
            Circle c(0, 0, 5);
            c.Output();
            break;
        }
        case '4': {
            Circle c;
            c.Input();
            double r;
            cout << "New radius: ";
            cin >> r;
            c.setRadius(r);
            c.Output();
            break;
        }
        case 'q':
            break;
        default:
            cout << "Wrong choice\n";
        }

    } while (choice != 'q');

    cout << "Exit program\n";
    return 0;
}
